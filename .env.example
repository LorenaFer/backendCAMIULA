DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/camiula_db
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
DEBUG=True

# Auth provider: "local" (dev/testing) o "auth0" (producción)
AUTH_PROVIDER=local

# Auth0 (solo si AUTH_PROVIDER=auth0)
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_API_AUDIENCE=https://api.camiula.com
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret

# Caché de permisos (segundos)
PERMISSION_CACHE_TTL_SECONDS=300
