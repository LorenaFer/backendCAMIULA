# ─── Database ────────────────────────────────────────────────
# Local development:
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/camiula_db
# Supabase cloud (development/testing):
# DATABASE_URL=postgresql+asyncpg://postgres.PROJECT:PASSWORD@aws-1-us-west-2.pooler.supabase.com:5432/postgres

# ─── Security ────────────────────────────────────────────────
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ─── App ─────────────────────────────────────────────────────
DEBUG=True
PORT=8000

# ─── Auth ────────────────────────────────────────────────────
# "local" for dev/testing, "auth0" for production
AUTH_PROVIDER=local

# Auth0 (only if AUTH_PROVIDER=auth0)
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_API_AUDIENCE=https://api.camiula.com
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret

# ─── Cache ───────────────────────────────────────────────────
PERMISSION_CACHE_TTL_SECONDS=300
